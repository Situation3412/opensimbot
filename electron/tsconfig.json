  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist/electron",
    "rootDir": "../src/electron"
  },
  "include": ["../src/electron/**/*"]
} 